# Docker Compose deployment variables
# Copy this file to .env and replace the placeholder values before running:
# docker compose up -d --build

MYSQL_ROOT_PASSWORD=replace-with-a-strong-mysql-root-password
MYSQL_DATABASE=order_management
MYSQL_PORT=3306

JWT_SECRET=replace-with-at-least-32-random-bytes
DEEPSEEK_API_KEY=

BACKEND_PORT=8080
FRONTEND_PORT=80
REDIS_PORT=6379
