<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.ordermanagement.mapper.CouponMapper">

    <select id="selectActiveCoupons" resultType="org.example.ordermanagement.entity.Coupon">
        SELECT * FROM coupon
        WHERE status = 'ACTIVE'
        AND start_time &lt;= #{now}
        AND end_time &gt;= #{now}
        ORDER BY create_time DESC
    </select>

</mapper>
